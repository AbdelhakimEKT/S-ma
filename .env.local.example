# ============================================================
# Söma — Variables d'environnement
# Copiez ce fichier en .env.local et remplissez les valeurs.
# Ne commitez jamais .env.local.
# ============================================================

# --- Supabase ---
# Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...      # Clé secrète — serveur uniquement

# --- Stripe (mode test) ---
# Dashboard → Developers → API keys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
# Lancez : stripe listen --forward-to localhost:3000/api/webhooks/stripe
# Copiez le whsec_... affiché par la CLI Stripe
STRIPE_WEBHOOK_SECRET=whsec_...

# --- Emails (Resend) ---
# Dashboard Resend → API Keys
RESEND_API_KEY=re_...
# Optionnel: si tu n'as pas encore de domaine, garde onboarding@resend.dev
RESEND_FROM_EMAIL="Söma <onboarding@resend.dev>"
# Optionnel: en mode sans domaine, reroute tous les tests vers ta propre boite
RESEND_TEST_TO_EMAIL=votre-adresse@example.com

# --- Emails (Gmail SMTP) ---
# Recommandé si tu veux envoyer directement depuis une adresse Gmail
GMAIL_USER=soma.orleans@gmail.com
# Google Account → Security → App passwords
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
# Optionnel: nom + adresse affichés dans les emails
EMAIL_FROM_ADDRESS="Söma <soma.orleans@gmail.com>"
# Optionnel: inbox qui reçoit aussi les notifications internes
BOOKING_NOTIFICATION_EMAIL=soma.orleans@gmail.com

# --- App ---
# URL publique — localhost en dev, domaine en prod
NEXT_PUBLIC_APP_URL=http://localhost:3000
